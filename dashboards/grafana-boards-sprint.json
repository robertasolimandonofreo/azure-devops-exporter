{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource scraping azure-devops-exporter",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "title": "Azure DevOps — Boards & Sprint",
  "uid": "azure-devops-boards-sprint",
  "description": "Sprint health, work-item breakdown, lead time, velocity and delivery metrics filtered by iteration path.",
  "tags": ["azure-devops", "boards", "sprint"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "editable": true,
  "time": { "from": "now-30d", "to": "now" },
  "refresh": "5m",
  "templating": {
    "list": [
      {
        "name": "DS_PROMETHEUS",
        "type": "datasource",
        "query": "prometheus",
        "label": "Prometheus",
        "current": {}
      },
      {
        "name": "organization",
        "type": "query",
        "label": "Organization",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(azure_devops_boards_work_items_total, organization)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "project",
        "type": "query",
        "label": "Project",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(azure_devops_boards_work_items_total{organization=~\"$organization\"}, project)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "team",
        "type": "query",
        "label": "Team",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(azure_devops_boards_active_sprint_work_items_total{organization=~\"$organization\", project=~\"$project\"}, team)",
        "refresh": 2,
        "multi": true,
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" }
      },
      {
        "name": "sprint",
        "type": "query",
        "label": "Sprint (iteration_path)",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(azure_devops_boards_work_items_by_state{organization=~\"$organization\", project=~\"$project\"}, iteration_path)",
        "refresh": 2,
        "multi": false,
        "includeAll": false,
        "current": {}
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Active Sprint Overview",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Sprint Work Items (total)",
      "description": "Total work items in the active sprint for the selected team.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10 },
              { "color": "red", "value": 20 }
            ]
          },
          "mappings": [],
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(azure_devops_boards_active_sprint_work_items_total{organization=~\"$organization\", project=~\"$project\", team=~\"$team\"})",
          "instant": true,
          "legendFormat": "Work Items"
        }
      ]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Sprint Story Points committed",
      "description": "Committed story points for the active sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 40 },
              { "color": "red", "value": 80 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(azure_devops_boards_active_sprint_story_points_total{organization=~\"$organization\", project=~\"$project\", team=~\"$team\"})",
          "instant": true,
          "legendFormat": "Story Points"
        }
      ]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Team capacity (h/day)",
      "description": "Total team capacity in hours per day for the active sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 16 },
              { "color": "green", "value": 32 }
            ]
          },
          "unit": "h",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(azure_devops_boards_team_capacity_hours_per_day{organization=~\"$organization\", project=~\"$project\", team=~\"$team\"})",
          "instant": true,
          "legendFormat": "h/day"
        }
      ]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Blocked items",
      "description": "Work items currently flagged as blocked in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto",
        "orientation": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum(azure_devops_boards_work_items_blocked_total{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "Blocked"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "Sprint — Work Item Breakdown",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "type": "piechart",
      "title": "Work items by state (sprint)",
      "description": "Distribution of work items by state for the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 6 },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (state) (azure_devops_boards_work_items_by_state{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "piechart",
      "title": "Work items by type (sprint)",
      "description": "Distribution of work items by type for the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 6 },
      "options": {
        "pieType": "donut",
        "displayLabels": ["name", "value"],
        "legend": { "displayMode": "table", "placement": "right", "values": ["value", "percent"] }
      },
      "fieldConfig": { "defaults": { "unit": "short" } },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (work_item_type) (azure_devops_boards_work_items_by_state{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{work_item_type}}"
        }
      ]
    },
    {
      "id": 9,
      "type": "bargauge",
      "title": "Work items by assignee (sprint)",
      "description": "Number of work items per assignee in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 6 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "unit": "short",
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (assigned_to) (azure_devops_boards_work_items_by_assignee{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{assigned_to}}"
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Sprint — Story Points & Effort",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 11,
      "type": "bargauge",
      "title": "Story points by state (sprint)",
      "description": "Story points split by work-item state for the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 0, "y": 15 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "blue", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (state) (azure_devops_boards_story_points_total{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 12,
      "type": "bargauge",
      "title": "Effort by state (sprint)",
      "description": "Effort split by work-item state for the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 12, "x": 12, "y": 15 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "purple", "value": null }]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (state) (azure_devops_boards_effort_total{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{state}}"
        }
      ]
    },
    {
      "id": 13,
      "type": "row",
      "title": "Sprint — Lead Time",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 22 }
    },
    {
      "id": 14,
      "type": "barchart",
      "title": "Lead time by type (avg / p50 / p90 days) — sprint",
      "description": "Lead time statistics per work-item type for the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "options": {
        "xField": "work_item_type",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg by (work_item_type) (azure_devops_boards_lead_time_avg_days{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "Avg — {{work_item_type}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg by (work_item_type) (azure_devops_boards_lead_time_p50_days{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "p50 — {{work_item_type}}"
        },
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "avg by (work_item_type) (azure_devops_boards_lead_time_p90_days{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "p90 — {{work_item_type}}"
        }
      ]
    },
    {
      "id": 15,
      "type": "row",
      "title": "Sprint — Velocity & Delivery (last 5 sprints)",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 }
    },
    {
      "id": 16,
      "type": "barchart",
      "title": "Sprint velocity by team (story points)",
      "description": "Story points delivered per sprint per team — last 5 completed sprints.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "options": {
        "xField": "iteration",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": { "displayMode": "list", "placement": "bottom" }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (team, iteration) (azure_devops_boards_sprint_velocity_story_points{organization=~\"$organization\", project=~\"$project\", team=~\"$team\"})",
          "instant": true,
          "legendFormat": "{{team}} — {{iteration}}"
        }
      ]
    },
    {
      "id": 17,
      "type": "barchart",
      "title": "Sprint delivery status (last 5 sprints)",
      "description": "Count of on_time / late / not_delivered deliveries per team per sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "options": {
        "xField": "iteration",
        "orientation": "auto",
        "groupWidth": 0.7,
        "barWidth": 0.97,
        "legend": { "displayMode": "list", "placement": "bottom" },
        "stacking": "normal"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 1, "fillOpacity": 80 }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "on_time" },
            "properties": [{ "id": "color", "value": { "fixedColor": "green", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "late" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "not_delivered" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (status, iteration) (azure_devops_boards_sprint_delivery_total{organization=~\"$organization\", project=~\"$project\", team=~\"$team\"})",
          "instant": true,
          "legendFormat": "{{status}} — {{iteration}}"
        }
      ]
    },
    {
      "id": 18,
      "type": "row",
      "title": "Sprint — Quality & Hygiene",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 40 }
    },
    {
      "id": 19,
      "type": "bargauge",
      "title": "Bugs by severity (sprint)",
      "description": "Open bugs per severity level in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 0, "y": 41 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 3 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (severity) (azure_devops_boards_bugs_by_severity{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{severity}}"
        }
      ]
    },
    {
      "id": 20,
      "type": "bargauge",
      "title": "Stale items (sprint)",
      "description": "Work items unchanged for more than 14 days in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 8, "y": 41 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (work_item_type) (azure_devops_boards_work_items_stale_total{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{work_item_type}}"
        }
      ]
    },
    {
      "id": 21,
      "type": "bargauge",
      "title": "Items without estimate (sprint)",
      "description": "Work items with no story-point estimate in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 7, "w": 8, "x": 16, "y": 41 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (work_item_type) (azure_devops_boards_work_items_without_estimate_total{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "{{work_item_type}}"
        }
      ]
    },
    {
      "id": 22,
      "type": "row",
      "title": "Sprint — Work Item Age & Priority",
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 48 }
    },
    {
      "id": 23,
      "type": "table",
      "title": "Work item age (sprint)",
      "description": "Age in days for each open work item in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 14, "x": 0, "y": 49 },
      "options": {
        "footer": { "show": false }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "d",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 7 },
              { "color": "red", "value": 14 }
            ]
          }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "displayName", "value": "Age (days)" },
              { "id": "custom.displayMode", "value": "color-background" }
            ]
          }
        ]
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "azure_devops_boards_work_item_age_days{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"}",
          "instant": true,
          "legendFormat": "{{work_item_id}} — {{work_item_type}} — {{state}} — {{assigned_to}}"
        }
      ]
    },
    {
      "id": 24,
      "type": "bargauge",
      "title": "Work items by priority (sprint)",
      "description": "Open work items grouped by priority in the selected sprint.",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 9, "w": 10, "x": 14, "y": 49 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "showUnfilled": true,
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 3 },
              { "color": "red", "value": 8 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (priority, work_item_type) (azure_devops_boards_work_items_by_priority{organization=~\"$organization\", project=~\"$project\", iteration_path=~\"$sprint\"})",
          "instant": true,
          "legendFormat": "P{{priority}} — {{work_item_type}}"
        }
      ]
    }
  ]
}
