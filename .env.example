AZURE_DEVOPS_ORGANIZATION=my-org
# Optionally restrict a project to specific collectors with ":collector+collector"
# (repos, boards, pipelines, releases) — e.g. proj-a:pipelines+boards,proj-b:repos
AZURE_DEVOPS_PROJECTS=proj-a,proj-b
AZURE_DEVOPS_TOKEN=xxxxxxxxxxxxxxxx
AZURE_DEVOPS_API_URL=https://dev.azure.com
EXPORTER_PORT=8080
SCRAPE_INTERVAL_SECONDS=300
LOG_LEVEL=info
# Optional: break azure_devops_boards_work_items_by_custom_field_total down by
# project-specific work item fields (Azure DevOps reference names, not display names),
# each optionally followed by ":label" — e.g. Custom.Platform:platform,Custom.Squad
# AZURE_DEVOPS_BOARDS_CUSTOM_FIELDS=